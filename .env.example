# HLShajara environment variables
# Copy this file to .env.local and fill in the real values.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string used by Drizzle ORM.
# Example: postgres://user:password@localhost:5432/hlshajara
DATABASE_URL=

# ---------------------------------------------------------------------------
# Authentication (Better Auth)
# ---------------------------------------------------------------------------
# Secret key used by Better Auth to sign sessions and tokens.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Server-side URL of the auth endpoint.
# Example: https://hlshajara.com
BETTER_AUTH_URL=

# Public URL of the auth endpoint (exposed to the browser).
# Example: https://hlshajara.com
NEXT_PUBLIC_BETTER_AUTH_URL=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Public URL of the site (used for absolute links in API routes).
# Example: https://hlshajara.com
NEXT_PUBLIC_APP_URL=

# Optional base path for static export / GitHub Pages.
# Leave empty for root-domain deployments like https://hlshajara.com
# Use /HLShajara only for GitHub Pages project sites.
NEXT_PUBLIC_BASE_PATH=

# ---------------------------------------------------------------------------
# Analytics
# ---------------------------------------------------------------------------
# Optional Google Tag Manager container ID.
# Example: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# ---------------------------------------------------------------------------
# Spam protection (Google reCAPTCHA v3)
# ---------------------------------------------------------------------------
# Public site key shown in the browser.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Secret key used server-side to verify tokens. NEVER expose to the browser.
RECAPTCHA_SECRET_KEY=

# ---------------------------------------------------------------------------
# Social login (optional)
# ---------------------------------------------------------------------------
# Twitter/X OAuth credentials. Required only if Twitter login is enabled.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Build-time flags
# ---------------------------------------------------------------------------
# Set to 1 to produce a static export for GitHub Pages.
# Not needed for Node.js hosting on Hostinger/VPS.
EXPORT_STATIC=
